# Copy to .env and fill in. NEVER commit .env — it's in .gitignore.

# ============ Provider selection ============
# Hosted (default):   LLM_PROVIDER=openai   EMBEDDING_PROVIDER=openai
# Fully local /       LLM_PROVIDER=ollama   EMBEDDING_PROVIDER=ollama
# air-gapped:         (requires Ollama: https://ollama.com — see README)
# In-process embeds:  EMBEDDING_PROVIDER=local  (pip install -e ".[local]")
#
# WARNING: switching EMBEDDING_PROVIDER changes the vector space. The app
# will refuse to start against a corpus built with a different embedder —
# use a new CHROMA_COLLECTION or re-ingest your documents.
LLM_PROVIDER=openai
EMBEDDING_PROVIDER=openai

# --- OpenAI (required only when an "openai" provider is selected) ---
OPENAI_API_KEY=sk-your-key-here
CHAT_MODEL=gpt-4o-mini
EMBEDDING_MODEL=text-embedding-3-small

# --- Ollama (local inference) ---
OLLAMA_BASE_URL=http://localhost:11434
OLLAMA_CHAT_MODEL=llama3.1:8b
OLLAMA_EMBEDDING_MODEL=nomic-embed-text

# --- Optional overrides (defaults shown) ---
ENVIRONMENT=development
LOG_LEVEL=INFO
CHROMA_PERSIST_DIR=data/chroma
CHROMA_COLLECTION=werby_documents
CHUNK_SIZE=1000
CHUNK_OVERLAP=200
RETRIEVAL_TOP_K=5
